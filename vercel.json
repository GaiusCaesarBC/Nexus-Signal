{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "api/index.js", // <-- POINT TO YOUR NEW API ENTRY FILE
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "server/**",   // Include your entire server directory
          "api/**"      // Include your new api directory (e.g., api/index.js)
        ]
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js" // <-- REWRITE TO YOUR NEW API ENTRY FILE
    },
    {
      "source": "/(.*)",
      "destination": "/client/build/index.html"
    }
  ]
}