{
  "version": 2,
  "projects": [
    {
      "name": "client",
      "root": "client",
      "buildCommand": "npm run build",
      "outputDirectory": "build"
    },
    {
      "name": "server",
      "root": "server",
      "buildCommand": "npm install",
      "outputDirectory": ""
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/client/build/index.html"
    }
  ]
}